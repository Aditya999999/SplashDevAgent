# Backend Server Configurations
APP_NAME=SplashDevAgent
DEBUG=True

# Security Credentials
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# Core Persistence & Cache Stores
MONGODB_URI=mongodb://localhost:27017/splash_dev_agent
REDIS_URL=redis://localhost:6379/0

# Dynamic Model Selection (openai / anthropic)
LLM_PROVIDER=openai

# LLM Platform API Credentials
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Developer Loops Configurations
DEV_CACHE_TTL=3600
DEV_TIMEOUT_SECONDS=120
